    "editorInfo.foreground": "#8FBFD9",
    "diffEditor.insertedTextBackground": "#A8C6861A",
    "diffEditor.removedTextBackground": "#D977811A",
    "sideBar.background": "#1B2017",
    "sideBar.foreground": "#C4CFB8",
    "sideBar.border": "#31392B",
    "sideBarTitle.foreground": "#E7EDDD",
    "sideBarSectionHeader.background": "#242B20",
    "sideBarSectionHeader.foreground": "#B3A3D6",
    "activityBar.background": "#161A13",
    "activityBar.foreground": "#D98BA6",
    "activityBar.inactiveForeground": "#77866B",
    "activityBar.border": "#31392B",
    "activityBarBadge.background": "#D98BA6",
    "activityBarBadge.foreground": "#20261C",
    "titleBar.activeBackground": "#161A13",
    "titleBar.activeForeground": "#C4CFB8",
    "titleBar.inactiveBackground": "#161A13",
    "titleBar.inactiveForeground": "#77866B",
    "titleBar.border": "#31392B",
    "statusBar.background": "#161A13",
    "statusBar.foreground": "#B3A3D6",
    "statusBar.border": "#31392B",
    "statusBar.debuggingBackground": "#D98BA6",
    "statusBar.debuggingForeground": "#20261C",
    "statusBar.noFolderBackground": "#293024",
    "statusBarItem.remoteBackground": "#A8C686",
    "statusBarItem.remoteForeground": "#20261C",
    "statusBarItem.hoverBackground": "#414A3980",
    "tab.activeBackground": "#20261C",
    "tab.activeForeground": "#D98BA6",
    "tab.activeBorderTop": "#D98BA6",
    "tab.inactiveBackground": "#1B2017",
    "tab.inactiveForeground": "#97A48B",
    "tab.border": "#31392B",
    "tab.hoverBackground": "#293024",
    "editorGroupHeader.tabsBackground": "#1B2017",
    "editorGroupHeader.tabsBorder": "#31392B",
    "editorGroup.border": "#31392B",
    "panel.background": "#1B2017",
    "panel.border": "#31392B",
    "panelTitle.activeForeground": "#D98BA6",
    "panelTitle.activeBorder": "#D98BA6",
    "panelTitle.inactiveForeground": "#97A48B",
    "terminal.background": "#1B2017",
    "terminal.foreground": "#E7EDDD",
    "terminalCursor.foreground": "#D98BA6",
    "terminal.ansiBlack": "#66755B",
    "terminal.ansiRed": "#D97781",
    "terminal.ansiGreen": "#A8C686",
    "terminal.ansiYellow": "#DCCB7A",
    "terminal.ansiBlue": "#8FBFD9",
    "terminal.ansiMagenta": "#D98BA6",
    "terminal.ansiCyan": "#93CFC0",
    "terminal.ansiWhite": "#E7EDDD",
    "terminal.ansiBrightBlack": "#87957B",
    "terminal.ansiBrightRed": "#E8AABE",
    "terminal.ansiBrightGreen": "#C4DBA4",
    "terminal.ansiBrightYellow": "#EBE2A5",
    "terminal.ansiBrightBlue": "#B4D8E8",
    "terminal.ansiBrightMagenta": "#E6BCCC",
    "terminal.ansiBrightCyan": "#BCE0D6",
    "terminal.ansiBrightWhite": "#F5F8F0",
    "button.background": "#D98BA6",
    "button.foreground": "#20261C",
    "button.hoverBackground": "#E6BCCC",
    "button.secondaryBackground": "#414A39",
    "button.secondaryForeground": "#E7EDDD",
    "button.secondaryHoverBackground": "#54604A",
    "badge.background": "#B3A3D6",
    "badge.foreground": "#20261C",
    "input.background": "#293024",
    "input.foreground": "#E7EDDD",
    "input.border": "#414A39",
    "input.placeholderForeground": "#97A48B",
    "inputOption.activeBackground": "#54604A",
    "inputOption.activeBorder": "#D98BA6",
    "focusBorder": "#B3A3D6",
    "dropdown.background": "#293024",
    "dropdown.foreground": "#E7EDDD",
    "dropdown.border": "#414A39",
    "list.activeSelectionBackground": "#414A39",
    "list.activeSelectionForeground": "#D98BA6",
    "list.inactiveSelectionBackground": "#31392B",
    "list.hoverBackground": "#293024",
    "list.focusBackground": "#414A39",
    "list.highlightForeground": "#D98BA6",
    "list.errorForeground": "#D97781",
    "list.warningForeground": "#DDAF6F",
    "tree.indentGuidesStroke": "#414A39",
    "scrollbarSlider.background": "#414A3966",
    "scrollbarSlider.hoverBackground": "#54604A99",
    "scrollbarSlider.activeBackground": "#66755BAA",
    "notificationCenterHeader.background": "#293024",
    "notifications.background": "#293024",
    "notifications.border": "#414A39",
    "notificationLink.foreground": "#8FBFD9",
    "pickerGroup.foreground": "#B3A3D6",
    "pickerGroup.border": "#414A39",
    "quickInput.background": "#293024",
    "quickInputList.focusBackground": "#414A39",
    "peekView.border": "#B3A3D6",
    "peekViewEditor.background": "#242B20",
    "peekViewResult.background": "#1B2017",
    "peekViewTitle.background": "#293024",
    "peekViewResult.matchHighlightBackground": "#D9B98C3A",
    "peekViewEditor.matchHighlightBackground": "#D9B98C3A",
    "gitDecoration.addedResourceForeground": "#A8C686",
    "gitDecoration.modifiedResourceForeground": "#8FBFD9",
    "gitDecoration.deletedResourceForeground": "#D97781",
    "gitDecoration.untrackedResourceForeground": "#C4DBA4",
    "gitDecoration.ignoredResourceForeground": "#66755B",
    "gitDecoration.conflictingResourceForeground": "#D9B98C",
    "breadcrumb.foreground": "#97A48B",
    "breadcrumb.focusForeground": "#E7EDDD",
    "breadcrumb.activeSelectionForeground": "#D98BA6",
    "menu.background": "#293024",
    "menu.foreground": "#E7EDDD",
    "menu.selectionBackground": "#414A39",
    "menu.selectionForeground": "#D98BA6",
    "menubar.selectionBackground": "#414A3980",
    "widget.shadow": "#00000066",
    "textLink.foreground": "#8FBFD9",
    "textLink.activeForeground": "#B4D8E8",
    "textPreformat.foreground": "#D9B98C",
    "progressBar.background": "#D98BA6",
    "selection.background": "#54604A",
    "walkThrough.embeddedEditorBackground": "#1B2017",
    "debugToolBar.background": "#293024",
    "debugIcon.breakpointForeground": "#D97781",
    "minimap.selectionHighlight": "#54604A",
    "minimap.findMatchHighlight": "#D9B98C",
    "minimapGutter.addedBackground": "#A8C686",
    "minimapGutter.modifiedBackground": "#8FBFD9",
    "minimapGutter.deletedBackground": "#D97781"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#87957B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#A8C686"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#D98BA6"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#D9B98C"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#93CFC0"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D98BA6"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#B3A3D6"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#8FBFD9"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#E5CDA9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Classes, types, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#B3A3D6"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#D9B98C"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#E7EDDD"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#D5DECA"
      }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#D98BA6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#DCCB7A"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#D98BA6"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B3A3D6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#8FBFD9"
      }
    },
    {
      "name": "CSS classes and ids",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#D9B98C"
      }
    },
    {
      "name": "JSON property keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8FBFD9"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#D98BA6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#D9B98C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#B3A3D6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#8FBFD9"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#A8C686"
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#87957B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#A8C686"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#D97781"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#8FBFD9"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#ADBAA0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#D97781"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#B3A3D6",
    "class": "#B3A3D6",
    "enum": "#B3A3D6",
    "interface": "#B3A3D6",
    "typeParameter": "#B3A3D6",
    "function": "#8FBFD9",
    "method": "#8FBFD9",
    "decorator": "#DCCB7A",
    "macro": "#DCCB7A",
    "parameter": {
      "foreground": "#E5CDA9",
      "italic": true
    },
    "property": "#D5DECA",
    "enumMember": "#D9B98C",
    "variable.readonly": "#D9B98C",
    "selfParameter": {
      "foreground": "#D98BA6",
      "italic": true
    },
    "clsParameter": {
      "foreground": "#D98BA6",
      "italic": true
    },
    "*.builtin": "#D98BA6"
  }
}
