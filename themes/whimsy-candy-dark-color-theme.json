    "editorInfo.foreground": "#9DD6F5",
    "diffEditor.insertedTextBackground": "#A8E6CF1A",
    "diffEditor.removedTextBackground": "#FF8FA31A",

    "sideBar.background": "#191627",
    "sideBar.foreground": "#C5BEDD",
