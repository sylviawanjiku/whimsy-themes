    "sideBarSectionHeader.background": "#211D33",
    "sideBarSectionHeader.foreground": "#C9B8F0",

    "activityBar.background": "#151321",
    "activityBar.foreground": "#F5A3C7",
    "activityBar.inactiveForeground": "#6B6488",
    "activityBar.border": "#2A2540",
    "activityBarBadge.background": "#F5A3C7",
    "activityBarBadge.foreground": "#1E1B2E",

    "titleBar.activeBackground": "#151321",
    "titleBar.activeForeground": "#C5BEDD",
    "titleBar.inactiveBackground": "#151321",
    "titleBar.inactiveForeground": "#6B6488",
    "titleBar.border": "#2A2540",

    "statusBar.background": "#151321",
    "statusBar.foreground": "#C9B8F0",
    "statusBar.border": "#2A2540",
    "statusBar.debuggingBackground": "#F5A3C7",
    "statusBar.debuggingForeground": "#1E1B2E",
    "statusBar.noFolderBackground": "#252138",
    "statusBarItem.remoteBackground": "#A8E6CF",
    "statusBarItem.remoteForeground": "#1E1B2E",
    "statusBarItem.hoverBackground": "#3A345480",

    "tab.activeBackground": "#1E1B2E",
    "tab.activeForeground": "#F5A3C7",
    "tab.activeBorderTop": "#F5A3C7",
    "tab.inactiveBackground": "#191627",
    "tab.inactiveForeground": "#8A82A8",
    "tab.border": "#2A2540",
    "tab.hoverBackground": "#252138",
    "editorGroupHeader.tabsBackground": "#191627",
    "editorGroupHeader.tabsBorder": "#2A2540",
    "editorGroup.border": "#2A2540",

    "panel.background": "#191627",
    "panel.border": "#2A2540",
    "panelTitle.activeForeground": "#F5A3C7",
    "panelTitle.activeBorder": "#F5A3C7",
    "panelTitle.inactiveForeground": "#8A82A8",

    "terminal.background": "#191627",
    "terminal.foreground": "#E8E3F5",
    "terminalCursor.foreground": "#F5A3C7",
    "terminal.ansiBlack": "#585174",
    "terminal.ansiRed": "#FF8FA3",
    "terminal.ansiGreen": "#A8E6CF",
    "terminal.ansiYellow": "#F5E6A8",
    "terminal.ansiBlue": "#9DD6F5",
    "terminal.ansiMagenta": "#F5A3C7",
    "terminal.ansiCyan": "#A8E0E6",
    "terminal.ansiWhite": "#E8E3F5",
    "terminal.ansiBrightBlack": "#7A7295",
    "terminal.ansiBrightRed": "#FFB3C1",
    "terminal.ansiBrightGreen": "#C4F0DD",
    "terminal.ansiBrightYellow": "#FAF0C8",
    "terminal.ansiBrightBlue": "#BEE4FA",
    "terminal.ansiBrightMagenta": "#FAC1DA",
    "terminal.ansiBrightCyan": "#C4ECF0",
    "terminal.ansiBrightWhite": "#F7F4FD",

    "button.background": "#F5A3C7",
    "button.foreground": "#1E1B2E",
    "button.hoverBackground": "#FAC1DA",
    "button.secondaryBackground": "#3A3454",
    "button.secondaryForeground": "#E8E3F5",
    "button.secondaryHoverBackground": "#4A3D66",

    "badge.background": "#C9B8F0",
    "badge.foreground": "#1E1B2E",

    "input.background": "#252138",
    "input.foreground": "#E8E3F5",
    "input.border": "#3A3454",
    "input.placeholderForeground": "#8A82A8",
    "inputOption.activeBackground": "#4A3D66",
    "inputOption.activeBorder": "#F5A3C7",
    "focusBorder": "#C9B8F0",

    "dropdown.background": "#252138",
    "dropdown.foreground": "#E8E3F5",
    "dropdown.border": "#3A3454",

    "list.activeSelectionBackground": "#3A3454",
    "list.activeSelectionForeground": "#F5A3C7",
    "list.inactiveSelectionBackground": "#2A2540",
    "list.hoverBackground": "#252138",
    "list.focusBackground": "#3A3454",
    "list.highlightForeground": "#F5A3C7",
    "list.errorForeground": "#FF8FA3",
    "list.warningForeground": "#FFD9A8",
    "tree.indentGuidesStroke": "#3A3454",

    "scrollbarSlider.background": "#3A345466",
    "scrollbarSlider.hoverBackground": "#4A3D6699",
    "scrollbarSlider.activeBackground": "#585174AA",

    "notificationCenterHeader.background": "#252138",
    "notifications.background": "#252138",
    "notifications.border": "#3A3454",
    "notificationLink.foreground": "#9DD6F5",

    "pickerGroup.foreground": "#C9B8F0",
    "pickerGroup.border": "#3A3454",
    "quickInput.background": "#252138",
    "quickInputList.focusBackground": "#3A3454",

    "peekView.border": "#C9B8F0",
    "peekViewEditor.background": "#211D33",
    "peekViewResult.background": "#191627",
    "peekViewTitle.background": "#252138",
    "peekViewResult.matchHighlightBackground": "#FFCBA83A",
    "peekViewEditor.matchHighlightBackground": "#FFCBA83A",

    "gitDecoration.addedResourceForeground": "#A8E6CF",
    "gitDecoration.modifiedResourceForeground": "#9DD6F5",
    "gitDecoration.deletedResourceForeground": "#FF8FA3",
    "gitDecoration.untrackedResourceForeground": "#C4F0DD",
    "gitDecoration.ignoredResourceForeground": "#585174",
    "gitDecoration.conflictingResourceForeground": "#FFCBA8",

    "breadcrumb.foreground": "#8A82A8",
    "breadcrumb.focusForeground": "#E8E3F5",
    "breadcrumb.activeSelectionForeground": "#F5A3C7",

    "menu.background": "#252138",
    "menu.foreground": "#E8E3F5",
    "menu.selectionBackground": "#3A3454",
    "menu.selectionForeground": "#F5A3C7",
    "menubar.selectionBackground": "#3A345480",

    "widget.shadow": "#00000066",
    "textLink.foreground": "#9DD6F5",
    "textLink.activeForeground": "#BEE4FA",
    "textPreformat.foreground": "#FFCBA8",
    "progressBar.background": "#F5A3C7",
    "selection.background": "#4A3D66",
    "walkThrough.embeddedEditorBackground": "#191627",

    "debugToolBar.background": "#252138",
    "debugIcon.breakpointForeground": "#FF8FA3",

    "minimap.selectionHighlight": "#4A3D66",
    "minimap.findMatchHighlight": "#FFCBA8",
    "minimapGutter.addedBackground": "#A8E6CF",
    "minimapGutter.modifiedBackground": "#9DD6F5",
    "minimapGutter.deletedBackground": "#FF8FA3"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7A7295",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": {
        "foreground": "#A8E6CF"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#F5A3C7"
      }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#FFCBA8"
      }
    },
    {
      "name": "Regular expressions",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#A8E0E6"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#F5A3C7"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#C9B8F0"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#9DD6F5"
      }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#FFDFC7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Classes, types, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#C9B8F0"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FFCBA8"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": {
        "foreground": "#E8E3F5"
      }
    },
    {
      "name": "Object properties",
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": {
        "foreground": "#D6CFEC"
      }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#F5A3C7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#F5E6A8"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#F5A3C7"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#C9B8F0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property names",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#9DD6F5"
      }
    },
    {
      "name": "CSS classes and ids",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#FFCBA8"
      }
    },
    {
      "name": "JSON property keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#9DD6F5"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#F5A3C7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#FFCBA8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#C9B8F0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#9DD6F5"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#A8E6CF"
      }
    },
    {
      "name": "Markdown quotes",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#7A7295",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#A8E6CF"
      }
    },
    {
      "name": "Diff deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#FF8FA3"
      }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#9DD6F5"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#A79ECB"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#FF8FA3"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#C9B8F0",
    "class": "#C9B8F0",
    "enum": "#C9B8F0",
    "interface": "#C9B8F0",
    "typeParameter": "#C9B8F0",
    "function": "#9DD6F5",
    "method": "#9DD6F5",
    "decorator": "#F5E6A8",
    "macro": "#F5E6A8",
    "parameter": { "foreground": "#FFDFC7", "italic": true },
    "property": "#D6CFEC",
    "enumMember": "#FFCBA8",
    "variable.readonly": "#FFCBA8",
    "selfParameter": { "foreground": "#F5A3C7", "italic": true },
    "clsParameter": { "foreground": "#F5A3C7", "italic": true },
    "*.builtin": "#F5A3C7"
  }
}
