    "editorBracketPairGuide.background6": "#F5E6A84D",
    "editorBracketPairGuide.activeBackground1": "#F5A3C7",
    "editorBracketPairGuide.activeBackground2": "#A8E6CF",
    "editorBracketPairGuide.activeBackground3": "#9DD6F5",
    "editorBracketPairGuide.activeBackground4": "#FFCBA8",
    "editorBracketPairGuide.activeBackground5": "#C9B8F0",
    "editorBracketPairGuide.activeBackground6": "#F5E6A8",
