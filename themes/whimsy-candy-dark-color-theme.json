    "editorSuggestWidget.background": "#252138",
    "editorSuggestWidget.border": "#3A3454",
    "editorSuggestWidget.selectedBackground": "#3A3454",
    "editorSuggestWidget.highlightForeground": "#F5A3C7",
    "editorHoverWidget.background": "#252138",
    "editorHoverWidget.border": "#3A3454",
    "editorError.foreground": "#FF8FA3",
