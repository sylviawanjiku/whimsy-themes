    "activityBarBadge.background": "#FF6EC7",
    "activityBarBadge.foreground": "#16102E",
    "titleBar.activeBackground": "#0E081F",
    "titleBar.activeForeground": "#C8BFE8",
    "titleBar.inactiveBackground": "#0E081F",
    "titleBar.inactiveForeground": "#6F63A3",
    "titleBar.border": "#2A2050",
    "statusBar.background": "#0E081F",
    "statusBar.foreground": "#B98CFF",
