    "panelTitle.activeBorder": "#FF6EC7",
    "panelTitle.inactiveForeground": "#948AC2",
    "terminal.background": "#120B26",
    "terminal.foreground": "#EDE7FF",
    "terminalCursor.foreground": "#FF6EC7",
    "terminal.ansiBlack": "#5C4E91",
    "terminal.ansiRed": "#FF5C8A",
    "terminal.ansiGreen": "#50FAC8",
    "terminal.ansiYellow": "#F5EA61",
    "terminal.ansiBlue": "#5CC8FF",
    "terminal.ansiMagenta": "#FF6EC7",
    "terminal.ansiCyan": "#6BF7EE",
    "terminal.ansiWhite": "#EDE7FF",
    "terminal.ansiBrightBlack": "#7E71B0",
    "terminal.ansiBrightRed": "#FF9AD5",
    "terminal.ansiBrightGreen": "#8CFFDD",
    "terminal.ansiBrightYellow": "#FFF7A1",
    "terminal.ansiBrightBlue": "#9FE0FF",
    "terminal.ansiBrightMagenta": "#FFB3E6",
    "terminal.ansiBrightCyan": "#A6FBF4",
    "terminal.ansiBrightWhite": "#FAF7FF",
    "button.background": "#FF6EC7",
    "button.foreground": "#16102E",
    "button.hoverBackground": "#FFB3E6",
    "button.secondaryBackground": "#3A2D6B",
    "button.secondaryForeground": "#EDE7FF",
    "button.secondaryHoverBackground": "#4B3A85",
    "badge.background": "#B98CFF",
    "badge.foreground": "#16102E",
    "input.background": "#201840",
    "input.foreground": "#EDE7FF",
    "input.border": "#3A2D6B",
    "input.placeholderForeground": "#948AC2",
    "inputOption.activeBackground": "#4B3A85",
    "inputOption.activeBorder": "#FF6EC7",
    "focusBorder": "#B98CFF",
    "dropdown.background": "#201840",
    "dropdown.foreground": "#EDE7FF",
    "dropdown.border": "#3A2D6B",
    "list.activeSelectionBackground": "#3A2D6B",
    "list.activeSelectionForeground": "#FF6EC7",
    "list.inactiveSelectionBackground": "#2A2050",
    "list.hoverBackground": "#201840",
    "list.focusBackground": "#3A2D6B",
    "list.highlightForeground": "#FF6EC7",
    "list.errorForeground": "#FF5C8A",
    "list.warningForeground": "#FFC46B",
    "tree.indentGuidesStroke": "#3A2D6B",
    "scrollbarSlider.background": "#3A2D6B66",
    "scrollbarSlider.hoverBackground": "#4B3A8599",
    "scrollbarSlider.activeBackground": "#5C4E91AA",
    "notificationCenterHeader.background": "#201840",
    "notifications.background": "#201840",
    "notifications.border": "#3A2D6B",
    "notificationLink.foreground": "#5CC8FF",
    "pickerGroup.foreground": "#B98CFF",
    "pickerGroup.border": "#3A2D6B",
    "quickInput.background": "#201840",
    "quickInputList.focusBackground": "#3A2D6B",
    "peekView.border": "#B98CFF",
    "peekViewEditor.background": "#1B1436",
    "peekViewResult.background": "#120B26",
    "peekViewTitle.background": "#201840",
    "peekViewResult.matchHighlightBackground": "#FFAE573A",
    "peekViewEditor.matchHighlightBackground": "#FFAE573A",
    "gitDecoration.addedResourceForeground": "#50FAC8",
    "gitDecoration.modifiedResourceForeground": "#5CC8FF",
    "gitDecoration.deletedResourceForeground": "#FF5C8A",
    "gitDecoration.untrackedResourceForeground": "#8CFFDD",
    "gitDecoration.ignoredResourceForeground": "#5C4E91",
    "gitDecoration.conflictingResourceForeground": "#FFAE57",
    "breadcrumb.foreground": "#948AC2",
    "breadcrumb.focusForeground": "#EDE7FF",
    "breadcrumb.activeSelectionForeground": "#FF6EC7",
    "menu.background": "#201840",
    "menu.foreground": "#EDE7FF",
    "menu.selectionBackground": "#3A2D6B",
    "menu.selectionForeground": "#FF6EC7",
    "menubar.selectionBackground": "#3A2D6B80",
    "widget.shadow": "#00000066",
    "textLink.foreground": "#5CC8FF",
    "textLink.activeForeground": "#9FE0FF",
    "textPreformat.foreground": "#FFAE57",
    "progressBar.background": "#FF6EC7",
    "selection.background": "#4B3A85",
    "walkThrough.embeddedEditorBackground": "#120B26",
    "debugToolBar.background": "#201840",
    "debugIcon.breakpointForeground": "#FF5C8A",
    "minimap.selectionHighlight": "#4B3A85",
    "minimap.findMatchHighlight": "#FFAE57",
    "minimapGutter.addedBackground": "#50FAC8",
    "minimapGutter.modifiedBackground": "#5CC8FF",
    "minimapGutter.deletedBackground": "#FF5C8A"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7E71B0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#50FAC8"
      }
    },
    {
      "name": "String interpolation punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#FF6EC7"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FFAE57"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#6BF7EE"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF6EC7"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#B98CFF"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#5CC8FF"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#FFC79E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Classes, types, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#B98CFF"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#FFAE57"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#EDE7FF"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#DAD2F2"
      }
    },
    {
      "name": "Language variables (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#FF6EC7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators and annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#F5EA61"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#FF6EC7"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B98CFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#5CC8FF"
      }
    },
    {
      "name": "CSS classes and ids",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#FFAE57"
      }
    },
    {
      "name": "JSON property keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#5CC8FF"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#FF6EC7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFAE57",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#B98CFF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#5CC8FF"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#50FAC8"
      }
    },
    {
      "name": "Markdown quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7E71B0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#50FAC8"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF5C8A"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#5CC8FF"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.accessor",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#ABA0DB"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF5C8A"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#B98CFF",
    "class": "#B98CFF",
    "enum": "#B98CFF",
    "interface": "#B98CFF",
    "typeParameter": "#B98CFF",
    "function": "#5CC8FF",
    "method": "#5CC8FF",
    "decorator": "#F5EA61",
    "macro": "#F5EA61",
    "parameter": {
      "foreground": "#FFC79E",
      "italic": true
    },
    "property": "#DAD2F2",
    "enumMember": "#FFAE57",
    "variable.readonly": "#FFAE57",
    "selfParameter": {
      "foreground": "#FF6EC7",
      "italic": true
    },
    "clsParameter": {
      "foreground": "#FF6EC7",
      "italic": true
    },
    "*.builtin": "#FF6EC7"
  }
}
