    "statusBar.debuggingBackground": "#FF6EC7",
    "statusBar.debuggingForeground": "#16102E",
    "statusBar.noFolderBackground": "#201840",
    "statusBarItem.remoteBackground": "#50FAC8",
    "statusBarItem.remoteForeground": "#16102E",
